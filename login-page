    `;
    document.head.appendChild(style);

    const arrowLeftSVG = `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>`;
    const arrowRightSVG = `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>`;

    let slidesHTML = CONFIG.slides.map((s, i) => `
        <div class="slide ${i === 0 ? 'active' : ''}" data-index="${i}">
            <div class="slide-text">
                ${s.smallLogo ? `<img src="${s.smallLogo}" class="small-logo">` : ''}
                <h1>${s.title}</h1>
                <h3>${s.subtitle}</h3>
                <p>${s.description}</p>
                <a href="${s.link}" class="slide-btn">Saiba mais</a>
            </div>
            <div class="slide-img"><img src="${s.heroImage}"></div>
        </div>`).join('');

    let dotsHTML = CONFIG.slides.map((_, i) => `<div class="dot ${i === 0 ? 'active' : ''}" data-index="${i}"></div>`).join('');
    let footerLinksHTML = CONFIG.footerLinks.map(l => `<a href="${l.url}" target="_blank">${l.text}</a>`).join('');

    const wrapperHTML = `
        <div id="${WRAPPER_ID}">
            <div class="carousel-card">
                <div class="slides-container">${slidesHTML}</div>
                <button class="nav-btn prev">${arrowLeftSVG}</button>
                <button class="nav-btn next">${arrowRightSVG}</button>
                <div class="dots-container">${dotsHTML}</div>
            </div>
            <div class="login-card-wrapper">
                <img src="${CONFIG.images.logoForm}" class="login-logo">
                <div id="form-container"></div>
            </div>
            <footer class="custom-footer">${footerLinksHTML}</footer>
        </div>`;

    document.body.insertAdjacentHTML('afterbegin', wrapperHTML);

    // ✅ NOVO: garante que exista um link de recuperação de senha visível
    function ensureResetLink() {
        const container = document.getElementById('form-container');
        if (!container) return;

        // Esconde qualquer link original de reset que possa ter vindo com o formulário para evitar duplicação/flicker
        const originalLinks = container.querySelectorAll('a[href*="reset/password"], a[href*="forgot"]');
        originalLinks.forEach(link => {
            // Se não for o nosso link injetado, esconde
            if (!link.parentNode.classList.contains('reset-password-injected')) {
                link.style.display = 'none';
            }
        });

        // Já injetamos o nosso?
        if (container.querySelector('.reset-password-injected')) return;

        // Preferência: colocar logo após o botão submit, se existir
        const form = container.querySelector('form');
        const submit = form ? form.querySelector('button[type="submit"], input[type="submit"]') : null;

        const wrap = document.createElement('div');
        wrap.className = 'reset-password-injected';
        wrap.innerHTML = `<a href="${CONFIG.auth.resetPasswordPath}">${CONFIG.auth.resetPasswordText}</a>`;

        if (submit && submit.parentNode) {
            // insere depois do submit
            submit.insertAdjacentElement('afterend', wrap);
        } else {
            // fallback: no final do container
            container.appendChild(wrap);
        }
    }

    // ✅ Verifica se existem alertas de erro perdidos no container original (#app) e os transfere
    function moveLostAlerts() {
        const myContainer = document.getElementById('form-container');
        if (!myContainer) return;

        // Tenta capturar alertas tanto do #app quanto de dentro do formulário se eles estiverem escondidos
        // Seletores comuns do MEGA/Vue
        const selectors = [
            '#app .callout', '#app .alert', '#app .error-message', 
            '#app .notification-banner', '#app div[class*="alert-"]',
            '.login-card-wrapper form .callout', '.login-card-wrapper form .alert' // Se já estiverem dentro mas escondidos
        ];
        
        const lostAlerts = document.querySelectorAll(selectors.join(', '));
        
        lostAlerts.forEach(alert => {
            // Ignora se for vazio
            if (!alert.innerText || alert.innerText.trim().length === 0) return;
            
            // Ignora se for o container do próprio formulário mascarado de alerta
            if (alert.contains(document.querySelector('input'))) return;

            // Se o alerta já está visível dentro do container, não faz nada
            if (myContainer.contains(alert) && alert.style.display !== 'none') return;

            // Se for um alerta "perdido" no #app, traz pra cá
            if (!myContainer.contains(alert)) {
                 myContainer.prepend(alert);
            }
        });
    }

    // --- MONITORAMENTO INTELIGENTE DE CONTEÚDO ---
    const checkForm = setInterval(() => {
        const myContainer = document.getElementById('form-container');
        if (!myContainer) return;

        let contentToMove = null;
        const newForm = document.querySelector('#app form');

        if (newForm && !myContainer.contains(newForm)) {
            const parentCard = newForm.closest('.bg-white') || newForm.closest('.dark\\:bg-n-solid-2');

            if (parentCard && parentCard.closest('#app')) {
                contentToMove = parentCard;
            } else {
                const parent = newForm.parentElement;
                if (parent && parent.children.length > 1 && parent.closest('#app')) {
                    contentToMove = parent;
                } else {
                    contentToMove = newForm;
                }
            }
        }

        if (contentToMove) {
            myContainer.innerHTML = '';
            if (contentToMove.tagName === 'FORM') {
                myContainer.appendChild(contentToMove);
            } else {
                while (contentToMove.firstChild) {
                    myContainer.appendChild(contentToMove.firstChild);
                }
            }
        }

        moveLostAlerts(); // Procura e move alertas órfãos
        // ✅ CHAMA SEMPRE (idempotente)
        ensureResetLink();

    }, 200);

    // ✅ NOVO: Intercepta erros de autenticação (401) e exibe mensagem ao usuário
    function showAuthError(message) {
        const container = document.getElementById('form-container');
        if (!container) return;

        // Remove erro anterior se existir
        const existingError = container.querySelector('.custom-auth-error');
        if (existingError) existingError.remove();

        const errorDiv = document.createElement('div');
        errorDiv.className = 'custom-auth-error';
        errorDiv.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 8px;">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            <span>${message}</span>
        `;
        
        // Insere no início do container, antes do form
        const form = container.querySelector('form');
        if (form) {
            form.insertAdjacentElement('beforebegin', errorDiv);
        } else {
            container.prepend(errorDiv);
        }

        // Auto-remove após 8 segundos
        setTimeout(() => {
            if (errorDiv.parentNode) {
                errorDiv.style.animation = 'fadeOut 0.3s ease-in-out forwards';
                setTimeout(() => errorDiv.remove(), 300);
            }
        }, 8000);
    }

    // Adiciona estilo para o erro customizado
    const errorStyle = document.createElement('style');
    errorStyle.innerHTML = `
        .custom-auth-error {
            background-color: #fef2f2 !important;
            border: 1px solid #fca5a5 !important;
            color: #991b1b !important;
            padding: 12px 16px !important;
            border-radius: 10px !important;
            font-size: 0.95rem !important;
            margin-bottom: 20px !important;
            width: 100% !important;
            box-sizing: border-box !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            animation: fadeIn 0.3s ease-in-out;
            font-weight: 500;
        }
        @keyframes fadeOut { 
            from { opacity: 1; transform: translateY(0); } 
            to { opacity: 0; transform: translateY(-10px); } 
        }
    `;
    document.head.appendChild(errorStyle);

    // Intercepta XMLHttpRequest para capturar erros 401
    const originalXHROpen = XMLHttpRequest.prototype.open;
    const originalXHRSend = XMLHttpRequest.prototype.send;

    XMLHttpRequest.prototype.open = function(method, url, ...rest) {
        this._url = url;
        this._method = method;
        return originalXHROpen.apply(this, [method, url, ...rest]);
    };

    XMLHttpRequest.prototype.send = function(body) {
        this.addEventListener('load', function() {
            if (this._url && this._url.includes('/auth/sign_in') && this.status === 401) {
                showAuthError('E-mail ou senha incorretos. Verifique suas credenciais.');
            }
        });
        return originalXHRSend.apply(this, [body]);
    };

    // Intercepta fetch para capturar erros 401 (caso o MEGA use fetch)
    const originalFetch = window.fetch;
    window.fetch = function(url, options) {
        return originalFetch.apply(this, arguments).then(response => {
            if (url && url.toString().includes('/auth/sign_in') && response.status === 401) {
                showAuthError('E-mail ou senha incorretos. Verifique suas credenciais.');
            }
            return response;
        });
    };

    // Carrossel
    let currentIndex = 0;
    const slides = document.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.dot');
    function showSlide(index) {
        if (index >= slides.length) index = 0;
        if (index < 0) index = slides.length - 1;
        currentIndex = index;
        slides.forEach(s => s.classList.remove('active'));
        slides[currentIndex].classList.add('active');
        dots.forEach(d => d.classList.remove('active'));
        dots[currentIndex].classList.add('active');
    }
    document.querySelector('.nav-btn.next').addEventListener('click', () => showSlide(currentIndex + 1));
    document.querySelector('.nav-btn.prev').addEventListener('click', () => showSlide(currentIndex - 1));
    dots.forEach(dot => dot.addEventListener('click', (e) => showSlide(parseInt(e.target.dataset.index))));
    setInterval(() => showSlide(currentIndex + 1), 6000);

})();
</script>
