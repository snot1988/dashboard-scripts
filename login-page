            smallLogo: "https://cdn-icons-png.flaticon.com/512/2111/2111463.png",
            heroImage: "https://internal-files.engedigital.com.br/images/ominichat.png?q=80&w=800&auto=format&fit=crop",
            link: "#"
        },
