        @keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

        /* Ajustes para notificações (toasts) que podem estar escondidos */
        .Vue-Toastification__container {
            z-index: 2147400000 !important;
            position: fixed !important;
        }

        /* Garante visibilidade de mensagens de erro */
        #form-container .callout, #form-container .alert, #form-container .error, 
        .login-card-wrapper .callout, .login-card-wrapper .alert, .login-card-wrapper .error {
            display: block !important;
