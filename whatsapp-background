  const encodedSvgLight = encodeURIComponent(
    doodleSvg.replace(/currentColor/g, '#3B4A54')
  );
  const encodedSvgDark = encodeURIComponent(
    doodleSvg.replace(/currentColor/g, '#8696A0')
  );

  const style = document.createElement('style');
  style.id = STYLE_ID;
  style.textContent = `
    /* ---------- Light mode ---------- */
    .conversation-panel {
      background-color: #D6CFC5 !important;
      background-image: url("data:image/svg+xml,${encodedSvgLight}") !important;
      background-repeat: repeat !important;
      background-size: 200px 200px !important;
    }

    /* ---------- Dark mode ---------- */
    .dark .conversation-panel {
      background-color: #0B141A !important;
      background-image: url("data:image/svg+xml,${encodedSvgDark}") !important;
    }
  `;
  document.head.appendChild(style);
})();
</script>
