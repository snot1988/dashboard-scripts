  <path d="M185 28c-3-8-14-8-14 2 0 6 14 16 14 16s14-10 14-16c0-10-11-10-14-2z" fill="none" stroke="currentColor" stroke-width="1.5"/>
  <!-- Câmera -->
  <rect x="245" y="22" rx="2" width="20" height="14" fill="none" stroke="currentColor" stroke-width="1.5"/>
  <circle cx="255" cy="29" r="4" fill="none" stroke="currentColor" stroke-width="1.5"/>
  <rect x="252" y="19" rx="1" width="8" height="4" fill="none" stroke="currentColor" stroke-width="1.5"/>
  <!-- Nota musical -->
  <circle cx="28" cy="105" r="5" fill="none" stroke="currentColor" stroke-width="1.5"/>
  <line x1="33" y1="105" x2="33" y2="88" stroke="currentColor" stroke-width="1.5"/>
  <path d="M33 88 Q40 85 40 92" fill="none" stroke="currentColor" stroke-width="1.5"/>
  <!-- Balão de chat -->
