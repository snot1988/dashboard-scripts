  <line x1="249" y1="100" x2="271" y2="100" stroke="currentColor" stroke-width="1"/>
  <!-- Estrela -->
  <polygon points="30,158 33,168 44,168 36,174 39,184 30,178 21,184 24,174 16,168 27,168" fill="none" stroke="currentColor" stroke-width="1.5"/>
  <!-- Livro -->
  <path d="M88 170 Q100 164 112 170 Q100 176 88 170 Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
